# Large package artifacts - upload final app packages through GitHub Releases instead

*.pkg.tar.zst
*.tar.zst
*.tar.gz
*.zip
*.7z

# Vendored packaging dependencies intentionally kept in Git.
# Keep only package artifacts, not extracted pkg/src build trees.
!packaging/native/prebuilt/
!packaging/native/prebuilt/*.pkg.tar.zst

!packaging/native/wgpu-stack/
!packaging/native/wgpu-stack/packages/
!packaging/native/wgpu-stack/packages/*.pkg.tar.zst
!packaging/native/wgpu-stack/python-pygfx/
!packaging/native/wgpu-stack/python-pygfx/*.pkg.tar.zst
!packaging/native/wgpu-stack/python-pylinalg/
!packaging/native/wgpu-stack/python-pylinalg/*.pkg.tar.zst
!packaging/native/wgpu-stack/python-rendercanvas/
!packaging/native/wgpu-stack/python-rendercanvas/*.pkg.tar.zst
!packaging/native/wgpu-stack/python-wgpu/
!packaging/native/wgpu-stack/python-wgpu/*.pkg.tar.zst

# Never commit extracted package build/install trees.
packaging/native/wgpu-stack/**/pkg/
packaging/native/wgpu-stack/**/src/
packaging/native/wgpu-stack/**/__pycache__/
packaging/native/wgpu-stack/**/*.pyc
packaging/native/wgpu-stack/**/*.whl

# Final built FAR MESH packages still stay out of normal Git

packaging/arch/
packaging/native/far-mesh-quad-native/*.pkg.tar.zst
packaging/native/far-mesh-quad-native/pkg/
packaging/native/far-mesh-quad-native/src/
packaging/native/far-mesh-quad-native/_staging/

# Built native wrapper binary inside packaging workdir

packaging/native/far-mesh-quad-native/far-mesh-quad-native

