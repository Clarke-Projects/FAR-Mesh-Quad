build() {
    cc -O2 -Wall -Wextra \
      -I/usr/include/python3.14 \
      -o "$srcdir/far-mesh-quad-native" \
      "$srcdir/far-mesh-quad-native-wrapper.c" \
      -L/usr/lib \
      -lpython3.14 \
      -ldl \
      -lm
}

package() {
    install -dm755 "$pkgdir/opt/far-mesh-quad-native"
    cp -a "$srcdir/far-mesh-quad-native-${pkgver}/." "$pkgdir/opt/far-mesh-quad-native/"

    install -Dm755 "$srcdir/far-mesh-quad-native" \
      "$pkgdir/usr/bin/far-mesh-quad-native"

    install -Dm644 "$srcdir/far-mesh-quad-native.desktop" \
      "$pkgdir/usr/share/applications/far-mesh-quad-native.desktop"

    install -Dm644 "$srcdir/far-mesh-quad-native.png" \
      "$pkgdir/usr/share/icons/hicolor/256x256/apps/far-mesh-quad-native.png"

    # FAR MESH Quad and bundled third-party license files.
    # Runtime/source-traceability copy inside app root.
    install -dm755 "$pkgdir/opt/far-mesh-quad-native/bin/License"

    install -m644 "$srcdir/LICENSE_FAR_Mesh_Quad.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_cgg-bern_quadwild-bimdf.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_instant-meshes.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_NumPy.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_Open3D.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_pygfx.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_pygfx_wgpu-py.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_pyside.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_pyvista.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_scikit-learn.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_SciPy.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_trimesh.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"
    install -m644 "$srcdir/LICENSE_VTK.txt" \
      "$pkgdir/opt/far-mesh-quad-native/bin/License/"

    # Standard Arch/CachyOS package-license location.
    install -dm755 "$pkgdir/usr/share/licenses/$pkgname"

    cp -a "$pkgdir/opt/far-mesh-quad-native/bin/License/." \
      "$pkgdir/usr/share/licenses/$pkgname/"

    find "$pkgdir/opt/far-mesh-quad-native/bin/License" -type d -exec chmod 755 {} +
    find "$pkgdir/opt/far-mesh-quad-native/bin/License" -type f -exec chmod 644 {} +
    find "$pkgdir/usr/share/licenses/$pkgname" -type d -exec chmod 755 {} +
    find "$pkgdir/usr/share/licenses/$pkgname" -type f -exec chmod 644 {} +
}
