)

makedepends=("tar" "zstd" "gcc" "python")

source=(
  "far-mesh-quad-native-${pkgver}.tar.zst"
  "far-mesh-quad-native-wrapper.c"
  "far-mesh-quad-native.desktop"
  "far-mesh-quad-native.png"
  "LICENSE_FAR_Mesh_Quad.txt"
  "LICENSE_cgg-bern_quadwild-bimdf.txt"
  "LICENSE_instant-meshes.txt"
  "LICENSE_NumPy.txt"
  "LICENSE_Open3D.txt"
  "LICENSE_pygfx.txt"
  "LICENSE_pygfx_wgpu-py.txt"
  "LICENSE_pyside.txt"
  "LICENSE_pyvista.txt"
  "LICENSE_scikit-learn.txt"
  "LICENSE_SciPy.txt"
  "LICENSE_trimesh.txt"
  "LICENSE_VTK.txt"
)

sha256sums=(
  "SKIP"
