pkgname=far-mesh-quad-native
pkgver=0.1.0
pkgrel=1
pkgdesc="FAR MESH Quad native no-venv package"
arch=("x86_64")
url="https://local.far-mesh"
license=("MIT" "BSD-2-Clause" "BSD-3-Clause" "GPL-3.0-only")

depends=(
